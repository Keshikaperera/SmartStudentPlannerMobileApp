<RegisterScreen>:
    canvas.before:
        Color:
            rgba: 0.12, 0.14, 0.22, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: [30, 50, 30, 40]
        spacing: 16

        Label:
            text: "Account Registry Portal"
            font_size: 24
            bold: True
            size_hint_y: None
            height: 45

        TextInput:
            id: reg_username
            hint_text: "Choose Username"
            multiline: False
            size_hint_y: None
            height: 46

        TextInput:
            id: reg_password
            hint_text: "Set Password"
            password: True
            multiline: False
            size_hint_y: None
            height: 46

        TextInput:
            id: reg_confirm
            hint_text: "Confirm Password"
            password: True
            multiline: False
            size_hint_y: None
            height: 46

        Label:
            id: reg_message
            text: ""
            font_size: 13
            color: 0.9, 0.4, 0.4, 1
            size_hint_y: None
            height: 25

        Button:
            text: "Submit and Register"
            font_size: 16
            bold: True
            size_hint_y: None
            height: 48
            background_normal: ""
            background_color: 0.25, 0.65, 0.45, 1
            on_release: root.do_register()

        Button:
            text: "⏮ Back to Sign In"
            font_size: 14
            size_hint_y: None
            height: 40
            background_color: 0.18, 0.20, 0.30, 1
            on_release: root.go_back()